/analyze_*.py
/binary_patcher.py
/compare_*.py
/complete_fragment_comparison.py
/deep_compare_*.py
/simple_template_replace.py
/template_generator.py
/template_generator_v2.py
/template_generator_v3.py
/test_*.py
/verify_*.py
VERSION_*.md
TEMPLATE_APPROACH_PLAN.md

# Gutenberg baseline corpus (large; not for git)
research/gutenberg-top-90/
research/gutenberg-top-90-baseline/*/

research/gutenberg-top-90-baseline-calibre/*/
